{
    "name": "xpens",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "bun run build && vite preview",
        "deploy": "bun run build && wrangler deploy",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "db:migrate": "wrangler d1 migrations apply xpens",
        "db:gen": "drizzle-kit generate --config drizzle.config.ts",
        "prepare": "husky"
    },
    "lint-staged": {
        "*": [
            "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
        ]
    },
    "dependencies": {
        "@base-ui/react": "^1.5.0",
        "@fontsource-variable/inter": "^5.2.8",
        "@tailwindcss/vite": "^4.3.1",
        "@tanstack/react-devtools": "^0.10.2",
        "@tanstack/react-form": "^1.29.1",
        "@tanstack/react-form-devtools": "^0.2.24",
        "@tanstack/react-query": "^5.100.9",
        "@tanstack/react-query-devtools": "^5.100.11",
        "@tanstack/react-router": "^1.170.18",
        "@tanstack/react-router-devtools": "^1.167.0",
        "@tanstack/react-table": "^8.21.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "hono": "^4.12.15",
        "lucide-react": "^1.21.0",
        "nanoid": "^5.1.11",
        "next-themes": "^0.4.6",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "shadcn": "^4.11.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.1",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.4",
        "@cloudflare/vite-plugin": "^1.34.0",
        "@eslint/js": "^10.0.1",
        "@tanstack/devtools-vite": "^0.8.1",
        "@tanstack/router-plugin": "^1.168.22",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.3",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.2",
        "vite": "^8.0.10",
        "wrangler": "^4.86.0"
    }
}
