{
    "name": "xpens",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "bun run build && vite preview",
        "deploy": "bun run build && wrangler deploy",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "db:migrate": "wrangler d1 migrations apply xpens",
        "db:gen": "drizzle-kit generate --config drizzle.config.ts",
        "prepare": "husky"
    },
    "lint-staged": {
        "*": [
            "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
        ]
    },
    "dependencies": {
        "@base-ui/react": "^1.6.0",
        "@fontsource-variable/inter": "^5.3.0",
        "@tailwindcss/vite": "^4.3.3",
        "@tanstack/react-devtools": "^0.10.9",
        "@tanstack/react-form": "^1.33.2",
        "@tanstack/react-form-devtools": "^0.2.31",
        "@tanstack/react-query": "^5.101.4",
        "@tanstack/react-query-devtools": "^5.101.4",
        "@tanstack/react-router": "^1.170.18",
        "@tanstack/react-router-devtools": "^1.167.0",
        "@tanstack/react-table": "^8.21.3",
        "better-auth": "^1.6.24",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "hono": "^4.12.31",
        "lucide-react": "^1.26.0",
        "nanoid": "^5.1.16",
        "next-themes": "^0.4.6",
        "react": "^19.2.8",
        "react-dom": "^19.2.8",
        "shadcn": "^4.14.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.3",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.4",
        "@cloudflare/vite-plugin": "^1.46.0",
        "@eslint/js": "^10.0.1",
        "@tanstack/devtools-vite": "^0.8.3",
        "@tanstack/router-plugin": "^1.168.23",
        "@types/node": "^25.9.5",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.4",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.7.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.2.0",
        "prettier": "^3.9.6",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.65.0",
        "vite": "^8.1.5",
        "wrangler": "^4.113.0"
    }
}
