{
    "name": "xpens",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "bun run build && vite preview",
        "deploy": "bun run build && wrangler deploy",
        "cf-typegen": "wrangler types --env-interface CloudflareBindings",
        "db:migrate": "wrangler d1 migrations apply xpens",
        "db:gen": "drizzle-kit generate --config drizzle.config.ts"
    },
    "dependencies": {
        "@tanstack/react-devtools": "^0.10.2",
        "@tanstack/react-form": "^1.29.1",
        "@tanstack/react-form-devtools": "^0.2.24",
        "@tanstack/react-query": "^5.100.9",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "hono": "^4.12.15",
        "nanoid": "^5.1.11",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.34.0",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "prettier": "^3.8.3",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.2",
        "vite": "^8.0.10",
        "wrangler": "^4.86.0"
    }
}
